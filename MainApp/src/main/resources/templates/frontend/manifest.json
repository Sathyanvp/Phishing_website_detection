{
  "manifest_version": 3,
  "name": "Phishing Risk Analyzer",
  "version": "1.0",
  "description": "Extract URL and DOM features for phishing detection",

  "permissions": [
    "tabs",
    "scripting",
    "activeTab",
	"storage"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}